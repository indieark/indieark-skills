    "default_model_preference",
    "first_use_config_preflight",
    "skipped_config_resume_prompt",
    "batch_generation_workflow",
    "model_specific_api_key_env",
    "nano_banana_route",
    "mj_proxy_route",
    "image_to_image_edit_route",
    "local_media_normalization",
    "transparent_output_postprocessing",
    "transparent_edge_decontamination",
    "hard_cli_execution_routing",
    "reference_image_reverse_prompting",
    "artifact_backed_result_reporting",
